    "df = pd.read_csv(\"results_0_3536.csv\", sep=\",\", header=None, index_col=False)\n",
    "df = df.rename(columns={0: \"Values\"})\n",
    "\n",
    "# Exact value S\n",
    "S = float(df.loc[0, \"Values\"])\n",
    "\n",
    "# Approximations (rows 1..100) as numeric series\n",
    "aprox = df.loc[1:100, \"Values\"].astype(float)\n",
    "\n",
    "# sorted estimates X(1) <= ... <= X(100)\n",
    "aprox_sorted = aprox.sort_values().reset_index(drop=True)\n",
    "\n",
    "\n",
    "\n",
    "# Constants\n",
    "eps = 0.3536\n",
    "m = math.ceil(8 / eps**2)\n",
    "\n",
    "# Statistics\n",
    "mean_est = aprox_sorted.mean()\n",
    "mse = ((aprox_sorted - S) ** 2).mean()\n",
    "empirical_var = ((aprox_sorted - aprox_sorted.mean())**2).mean()  # population var\n",
    "theoretical_var = (2 * S**2) / m\n",
    "print(\"S (true):\", S)\n",
    "print(\"Mean of estimates:\", mean_est)\n",
    "print(\"MSE (1/100 sum (X(i)-S)^2):\", mse)\n",
    "print(\"Theoretical var approximation 2*S^2/m:\", theoretical_var)\n",
    "print(\"Empirical variance (population):\", empirical_var)"
   ]
