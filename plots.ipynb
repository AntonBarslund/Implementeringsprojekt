    "\n",
    "def load_runs(path):\n",
    "    if not os.path.exists(path):\n",
    "        return []\n",
    "    rows = []\n",
    "    with open(path, 'r', encoding='utf-8') as f:\n",
    "        for line in f:\n",
    "            s = line.strip()\n",
    "            if not s or s.startswith('//') or s.startswith('#'):\n",
    "                continue\n",
    "            # Split by comma first\n",
    "            parts = s.split(',')\n",
    "            if len(parts) < 2:\n",
    "                continue\n",
    "            try:\n",
    "                it_str = parts[0].strip()\n",
    "                # Rejoin remaining parts and replace comma with dot for decimal\n",
    "                time_str = ','.join(parts[1:]).strip().replace(',', '.')\n",
    "                it = int(it_str)\n",
    "                t = float(time_str)\n",
    "                rows.append((it, t))\n",
    "            except Exception:\n",
    "                continue\n",
    "\n",
    "    # split into runs when iteration does not increase\n",
    "    runs = []\n",
    "    curr = []\n",
    "    prev_it = -1\n",
    "    for it, t in rows:\n",
    "        if prev_it != -1 and it <= prev_it:\n",
    "            if curr:\n",
    "                arr = np.array(curr)\n",
    "                runs.append((arr[:,0].astype(int), arr[:,1].astype(float)))\n",
    "            curr = []\n",
    "        curr.append((it, t))\n",
    "        prev_it = it\n",
    "    if curr:\n",
    "        arr = np.array(curr)\n",
    "        runs.append((arr[:,0].astype(int), arr[:,1].astype(float)))\n",
    "    return runs\n",
    "\n",
    "def plot_runs_overlay(shift_runs, prime_runs, ax):\n",
    "    if not shift_runs and not prime_runs:\n",
    "        ax.text(0.5, 0.5, 'No data', ha='center')\n",
    "        return\n",
    "    \n",
    "    # Process shift runs\n",
    "    if shift_runs:\n",
    "        all_x_shift = np.unique(np.concatenate([x for x, y in shift_runs]))\n",
    "        for x, y in shift_runs:\n",
    "            ax.plot(x, y, alpha=0.15, color='blue')\n",
    "        interp_shift = np.vstack([np.interp(all_x_shift, x, y) for x, y in shift_runs])\n",
    "        mean_shift = np.mean(interp_shift, axis=0)\n",
    "        ax.plot(all_x_shift, mean_shift, color='blue', linewidth=2.5, label='mult_shift mean')\n",
    "    \n",
    "    # Process prime runs\n",
    "    if prime_runs:\n",
    "        all_x_prime = np.unique(np.concatenate([x for x, y in prime_runs]))\n",
    "        for x, y in prime_runs:\n",
    "            ax.plot(x, y, alpha=0.15, color='red')\n",
    "        interp_prime = np.vstack([np.interp(all_x_prime, x, y) for x, y in prime_runs])\n",
    "        mean_prime = np.mean(interp_prime, axis=0)\n",
    "        ax.plot(all_x_prime, mean_prime, color='red', linewidth=2.5, label='mult_mod_prime mean')\n",
    "    \n",
    "    ax.set_xscale('log')\n",
    "    ax.set_xlabel('iterations (log scale)')\n",
    "    ax.set_ylabel('Runtime (s)')\n",
    "    ax.set_title('Multiplication Methods Comparison')\n",
    "    ax.legend()\n",
    "    ax.grid(True)\n",
    "\n",
    "def main():\n",
    "    base = '/Users/antonbarslund/Documents/GitHub/Implementeringsprojekt1'\n",
